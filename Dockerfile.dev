# 開発用の共有イメージ。next / server の両コンテナがこの1イメージから起動する。
# next は @daiius/...-server-ts/client (Hono RPC) を import するため、どちらの
# サービスにとってもワークスペース全体（next + server-ts + 全 node_modules）が必要で、
# 結果として両者の中身は一致する。ゆえにイメージを分ける意味がなく1本に集約している。
# 本番は別系統（next/Dockerfile.nextjs.prod / server-ts/Dockerfile.server.prod）。
FROM node:24-bookworm-slim

WORKDIR /workspace

# pnpm はルート package.json の packageManager フィールドから corepack が解決する
RUN corepack enable

# 依存定義のみ先に COPY（lockfile 変更時だけこの層が無効化される）
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY server-ts/package.json server-ts/tsconfig.json ./server-ts/
COPY next/package.json next/tsconfig.json ./next/

# pnpm store を BuildKit キャッシュに載せ、リビルド時の再ダウンロードを避ける
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# ソースをイメージに焼き込む（compose watch が差分だけ上書き同期する）
COPY server-ts/ ./server-ts/
COPY next/ ./next/

# 起動する package と command は compose 側で working_dir / command により指定する。
